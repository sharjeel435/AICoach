# OPENAI_API_KEY=replace_with_your_openai_api_key

OPENAI_MODEL=gpt-4
ADMIN_EMAIL=admin@example.com
# Optional comma-separated list for multiple bootstrap admins.
# ADMIN_EMAILS=admin@example.com,owner@example.com

COOKIE_SECURE=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1
# Free local AI option:
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
DATABASE_PATH=backend/coach.db
# Optional hosted persistence. Uncomment both; FastAPI rejects publishable keys.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key
